@using NorthwindApp.Controllers
@model IEnumerable<ProductoMasCompradoViewModel>

@{
    ViewData["Title"] = "Productos Más Comprados";
}

<div class="container py-4">
    <h1 class="mb-4">📈 Productos Más Comprados</h1>
    <p class="text-muted mb-4">
        Consulta LINQ: agrupa todos los <code>OrderDetails</code> por producto y calcula el total de unidades vendidas.
    </p>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No hay datos de ventas disponibles.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-bordered shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Producto</th>
                        <th class="text-center">Total Unidades Vendidas</th>
                        <th class="text-end">Total Ingresos</th>
                    </tr>
                </thead>
                <tbody>
                    @{int pos = 1;}
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (pos == 1) { <span class="badge bg-warning text-dark fs-6">🥇 @pos</span> }
                                else if (pos == 2) { <span class="badge bg-secondary fs-6">🥈 @pos</span> }
                                else if (pos == 3) { <span class="badge bg-danger fs-6">🥉 @pos</span> }
                                else { <span>@pos</span> }
                            </td>
                            <td class="fw-semibold">@item.ProductName</td>
                            <td class="text-center">
                                <span class="badge bg-primary fs-6">@item.TotalVendido unidades</span>
                            </td>
                            <td class="text-end fw-bold text-success">$@item.TotalIngresos.ToString("F2")</td>
                        </tr>
                        pos++;
                    }
                </tbody>
            </table>
        </div>
    }

    <a asp-action="Index" class="btn btn-outline-secondary mt-2">← Todas las Órdenes</a>
</div>
