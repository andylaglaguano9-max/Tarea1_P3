<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="NorthwindApp - Sistema de gestión y compras en línea" />
    <title>@ViewData["Title"] - NorthwindApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NorthwindApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shop-window"></i> NorthwindApp
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house"></i> Inicio
                            </a>
                        </li>

                        @* Menú para Customer *@
                        @if (User.IsInRole("Customer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Products" asp-action="Tienda">
                                    <i class="bi bi-cart3"></i> Tienda
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="ShoppingCart" asp-action="Index">
                                    <i class="bi bi-bag"></i> Mi Carrito
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Compras" asp-action="MisOrdenes">
                                    <i class="bi bi-receipt"></i> Mis Órdenes
                                </a>
                            </li>
                        }

                        @* Menú para Admin *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Products" asp-action="Tienda">
                                    <i class="bi bi-cart3"></i> Tienda
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="ShoppingCart" asp-action="Index">
                                    <i class="bi bi-bag"></i> Carrito
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-box-seam"></i> Catálogo
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-controller="Products" asp-action="Index"><i class="bi bi-grid"></i> Productos</a></li>
                                    <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index"><i class="bi bi-tags"></i> Categorías</a></li>
                                    <li><a class="dropdown-item" asp-controller="Suppliers" asp-action="Index"><i class="bi bi-truck"></i> Proveedores</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-bar-chart"></i> Inventario
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-controller="Products" asp-action="BajoStock"><i class="bi bi-exclamation-triangle text-warning"></i> Bajo Stock</a></li>
                                    <li><a class="dropdown-item" asp-controller="Products" asp-action="SinStock"><i class="bi bi-x-circle text-danger"></i> Sin Stock</a></li>
                                    <li><a class="dropdown-item" asp-controller="Products" asp-action="Descontinuados"><i class="bi bi-slash-circle text-secondary"></i> Descontinuados</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-journal-text"></i> Pedidos
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-controller="Orders" asp-action="Index"><i class="bi bi-list-ul"></i> Todas las Órdenes</a></li>
                                    <li><a class="dropdown-item" asp-controller="Orders" asp-action="ProductosMasComprados"><i class="bi bi-graph-up"></i> Más Comprados</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-search"></i> Consultas LINQ
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-controller="Products" asp-action="MasCaros"><i class="bi bi-currency-dollar"></i> Top 10 Más Caros</a></li>
                                    <li><a class="dropdown-item" asp-controller="Products" asp-action="BuscarPorNombre"><i class="bi bi-search"></i> Buscar por Nombre</a></li>
                                    <li><a class="dropdown-item" asp-controller="Products" asp-action="ProductosPorProveedor"><i class="bi bi-truck"></i> Por Proveedor</a></li>
                                    <li><a class="dropdown-item" asp-controller="Products" asp-action="ProductosPorCategoria"><i class="bi bi-diagram-3"></i> Por Categoría (Join)</a></li>
                                    <li><a class="dropdown-item" asp-controller="Products" asp-action="ProductosProveedorEspecifico"><i class="bi bi-funnel"></i> Proveedor USA &gt; $10</a></li>
                                </ul>
                            </li>
                        }

                        @* Menú para Employee *@
                        @if (User.IsInRole("Employee") && !User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Products" asp-action="Index">
                                    <i class="bi bi-grid"></i> Productos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Categories" asp-action="Index">
                                    <i class="bi bi-tags"></i> Categorías
                                </a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["Exito"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-1"></i> @TempData["Exito"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-octagon-fill me-1"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light mt-4">
        <div class="container py-2">
            &copy; 2026 - NorthwindApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
