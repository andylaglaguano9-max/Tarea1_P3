@model NorthwindApp.Models.Order

@{
    ViewData["Title"] = "Detalle de Orden #" + Model.OrderId;
    float totalOrden = (float)(ViewData["TotalOrden"] ?? 0f);
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🧾 Detalle de Orden <span class="text-primary">#@Model.OrderId</span></h1>
        <a asp-action="MisOrdenes" class="btn btn-outline-secondary">← Mis Órdenes</a>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title text-muted">Información de la Orden</h6>
                    <table class="table table-sm mb-0">
                        <tr><td><strong>Orden #:</strong></td><td>@Model.OrderId</td></tr>
                        <tr><td><strong>Fecha:</strong></td><td>@Model.OrderDate?.ToString("dd/MM/yyyy")</td></tr>
                        <tr><td><strong>Fecha Requerida:</strong></td><td>@Model.RequiredDate?.ToString("dd/MM/yyyy")</td></tr>
                        <tr><td><strong>País:</strong></td><td>@Model.ShipCountry</td></tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Productos de la Orden</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Producto</th>
                        <th class="text-end">Precio Unit.</th>
                        <th class="text-center">Cantidad</th>
                        <th class="text-center">Descuento</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detalle in Model.OrderDetails)
                    {
                        float subtotal = detalle.UnitPrice * detalle.Quantity;
                        <tr>
                            <td class="fw-semibold">@detalle.Product?.ProductName</td>
                            <td class="text-end">$@detalle.UnitPrice.ToString("F2")</td>
                            <td class="text-center">@detalle.Quantity</td>
                            <td class="text-center">@detalle.Discount.ToString("P0")</td>
                            <td class="text-end fw-bold text-success">$@subtotal.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-success">
                    <tr>
                        <td colspan="4" class="text-end fw-bold fs-5">TOTAL DE LA ORDEN:</td>
                        <td class="text-end fw-bold fs-5">$@totalOrden.ToString("F2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
