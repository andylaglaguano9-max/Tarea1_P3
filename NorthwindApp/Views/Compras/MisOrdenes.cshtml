@model IEnumerable<NorthwindApp.Models.Order>

@{
    ViewData["Title"] = "Mis Órdenes";
}

<div class="container py-4">
    <h1 class="mb-4">📋 Mis Órdenes</h1>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="display-3 text-muted">📦</div>
            <h4 class="text-muted mt-3">No tienes órdenes registradas aún</h4>
            <p class="text-muted">Realiza tu primera compra en la tienda.</p>
            <a asp-controller="Products" asp-action="Tienda" class="btn btn-primary btn-lg mt-2">
                🛒 Ir a la Tienda
            </a>
        </div>
    }
    else
    {
        <p class="text-muted mb-3">Tienes <strong>@Model.Count()</strong> órdenes registradas.</p>
        <div class="table-responsive">
            <table class="table table-hover table-bordered shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Orden #</th>
                        <th>Fecha</th>
                        <th>Fecha Requerida</th>
                        <th>Dirección de Envío</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="fw-bold text-primary">#@order.OrderId</td>
                            <td>@order.OrderDate?.ToString("dd/MM/yyyy")</td>
                            <td>@order.RequiredDate?.ToString("dd/MM/yyyy")</td>
                            <td>@order.ShipAddress, @order.ShipCity</td>
                            <td class="text-center">
                                <a asp-action="DetalleOrden" asp-route-id="@order.OrderId"
                                   class="btn btn-sm btn-outline-info">
                                    🔍 Ver Detalle
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
